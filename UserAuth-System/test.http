@baseUrl = http://localhost:8000
### ========================================
### 1. 用户注册测试
### ========================================

### 1.1 注册新用户（完整信息）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "zhangsan",
    "password": "zhangsan123",
    "nickname": "张三",
    "email": "zhangsan@example.com"
}

### 1.2 注册新用户（仅必填信息）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "lisi",
    "password": "lisi123",
    "nickname": "李四"
}

### 1.3 注册新用户（中文用户名）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "王小明",
    "password": "wang123",
    "nickname": "小明",
    "email": "wang@example.com"
}

### 1.4 注册新用户（英文+数字）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "alice_2024",
    "password": "alice123",
    "nickname": "Alice",
    "email": "alice@example.com"
}

### 1.5 测试注册重复用户名（应该失败）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "zhangsan",
    "password": "newpass123",
    "nickname": "张三重复"
}

### 1.6 测试注册用户名过短（应该失败）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "ab",
    "password": "password123",
    "nickname": "用户名太短"
}

### 1.7 测试注册密码过短（应该失败）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "shortpass",
    "password": "123",
    "nickname": "密码太短"
}

### 1.8 测试注册无效邮箱格式（应该失败）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "invalidemail",
    "password": "password123",
    "nickname": "邮箱错误",
    "email": "invalid-email"
}

### 1.9 测试注册已存在的邮箱（应该失败）
POST {{baseUrl}}/auth/register
Content-Type: application/json

{
    "username": "newuser",
    "password": "password123",
    "nickname": "新用户",
    "email": "zhangsan@example.com"
}

### ========================================
### 2. 用户登录测试
### ========================================

### 2.1 登录 - 正确的用户名密码
# @name login_zhangsan
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "username": "zhangsan",
    "password": "zhangsan123"
}

### 保存张三的token
# @token_zhangsan = {{login_zhangsan.response.body.access_token}}

### 2.2 登录 - 李四用户
# @name login_lisi
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "username": "lisi",
    "password": "lisi123"
}

### 保存李四的token
# @token_lisi = {{login_lisi.response.body.access_token}}

### 2.3 登录 - 中文用户名
# @name login_wang
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "username": "王小明",
    "password": "wang123"
}

### 保存王小明的token
# @token_wang = {{login_wang.response.body.access_token}}

### 2.4 登录 - 错误的密码（应该失败）
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "username": "zhangsan",
    "password": "wrongpassword"
}

### 2.5 登录 - 不存在的用户（应该失败）
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "username": "nonexistent",
    "password": "password123"
}

### 2.6 登录 - 用户名为空（应该失败）
POST {{baseUrl}}/auth/login
Content-Type: application/json

{
    "username": "",
    "password": "password123"
}

