# ### ========================================
# ### 7. 并发登录测试（同一用户多设备）
# ### ========================================

# ### 7.1 第一次登录（设备1）
# # @name login_device1
# POST {{baseUrl}}/auth/login
# Content-Type: application/json

# {
#     "username": "zhangsan",
#     "password": "zhangsan123"
# }

# ### 保存设备1的token
# # @token_device1 = {{login_device1.response.body.access_token}}

# ### 7.2 第二次登录（设备2）
# # @name login_device2
# POST {{baseUrl}}/auth/login
# Content-Type: application/json

# {
#     "username": "zhangsan",
#     "password": "zhangsan123"
# }

# ### 保存设备2的token
# @token_device2 = {{login_device2.response.body.access_token}}

# ### 7.3 设备1访问（应该成功）
# GET {{baseUrl}}/auth/me
# Authorization: Bearer {{token_device1}}

# ### 7.4 设备2访问（应该成功）
# GET {{baseUrl}}/auth/me
# Authorization: Bearer {{token_device2}}

# ### 7.5 设备1注销（只影响设备1）
# POST {{baseUrl}}/auth/logout
# Authorization: Bearer {{token_device1}}

# ### 7.6 设备1注销后访问（应该失败）
# GET {{baseUrl}}/auth/me
# Authorization: Bearer {{token_device1}}

# ### 7.7 设备2仍可访问（应该成功）
# GET {{baseUrl}}/auth/me
# Authorization: Bearer {{token_device2}}