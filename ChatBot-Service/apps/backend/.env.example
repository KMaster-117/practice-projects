# ======================
# 项目基础
# ======================
PROJECT_NAME=FastAPI
ENV=dev
DEBUG=True
HOST=0.0.0.0
PORT=8000

# ======================
# MySQL
# ======================
DB_URL=mysql://root:password@localhost:3306/Database

# ======================
# Redis
# ======================
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_DB=0

# ======================
# JWT 登录
# ======================
SECRET_KEY=your-secret-key-here
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080 # access_token 7天
REFRESH_TOKEN_EXPIRE_MINUTES=43200 # refresh_token 30天

# ======================
# Snowflake 配置
# ======================
WORK_ID=1

# ======================
# 项目创建时间
# ======================
PROJECT_CREATION_TIME=2020.1.1

# ======================
# 安全
# ======================
CORS_ORIGINS=["*"]

# ======================
# OpenAI
# ======================
CHAT_MODEL=your-chat_model
DASHSCOPE_API_KEY=your-dashscope-key-here
BASE_URL=your-base-url